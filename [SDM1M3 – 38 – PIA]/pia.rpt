ispLEVER Classic 2.1.00.02.49.20  -  Device Utilization Chart         Tue Nov 23 01:31:05 2021

P22V10G Programmed Logic:
--------------------------------------------------------------------------------



l0     = (  !q3.Q & !q1.Q & q0.Q 
          #   q3.Q & !q2.Q & !q1.Q & !q0.Q );

l1     = (  !q3.Q & q2.Q & !q0.Q 
          #   !q3.Q & q1.Q & !q0.Q 
          #   q3.Q & !q2.Q & !q1.Q & !q0.Q );

l2     = (  !q3.Q & !q2.Q & q0.Q 
          #   !q3.Q & q1.Q & q0.Q 
          #   q3.Q & !q2.Q & !q1.Q & !q0.Q );

l3     = (  !q3.Q & q2.Q & !q0.Q 
          #   !q3.Q & q1.Q & !q0.Q 
          #   q3.Q & !q2.Q & !q1.Q & !q0.Q );

l4     = (  !q3.Q & !q1.Q & q0.Q 
          #   q3.Q & !q2.Q & !q1.Q & !q0.Q );

q3.D   = (  !q3.Q & q2.Q & m0 & m1 
          #   !q3.Q & q1.Q & m0 & m1 
          #   !q3.Q & q0.Q & m0 & m1 
          #   q3.Q & !q2.Q & !q1.Q & !q0.Q & m0 & m1 
          #   q3.Q & !q2.Q & !q1.Q & !q0.Q & !m0 & !m1 ); " ISTYPE 'BUFFER'
q3.C   = (  clk );
q3.AR  = (  reset );

q2.D   = (  !q3.Q & q2.Q & !q1.Q & !m0 
          #   !q3.Q & q2.Q & !q0.Q & !m0 
          #   !q3.Q & !q2.Q & q1.Q & q0.Q & !m0 & m1 
          #   !q3.Q & q2.Q & q1.Q & !m1 
          #   !q3.Q & q2.Q & q0.Q & !m1 
          #   q3.Q & !q2.Q & !q1.Q & !q0.Q & m0 & !m1 ); " ISTYPE 'BUFFER'
q2.C   = (  clk );
q2.AR  = (  reset );

q1.D   = (  !q3.Q & q2.Q & q1.Q & !m0 
          #   !q3.Q & q1.Q & !q0.Q & !m0 
          #   !q3.Q & !q1.Q & q0.Q & !m0 & m1 
          #   !q3.Q & q1.Q & q0.Q & !m1 
          #   !q3.Q & !q2.Q & q0.Q & m0 & !m1 
          #   !q3.Q & q2.Q & !q1.Q & !q0.Q & m0 & !m1 
          #   q3.Q & !q2.Q & !q1.Q & !q0.Q & m0 & !m1 ); " ISTYPE 'BUFFER'
q1.C   = (  clk );
q1.AR  = (  reset );

q0.D   = (  !q3.Q & q2.Q & q1.Q & !m0 & m1 
          #   !q3.Q & !q0.Q & !m0 & m1 
          #   !q2.Q & !q1.Q & !q0.Q & !m0 & m1 
          #   !q3.Q & !q0.Q & m0 & !m1 
          #   !q2.Q & !q1.Q & !q0.Q & m0 & !m1 
          #   !q3.Q & q0.Q & !m0 & !m1 ); " ISTYPE 'BUFFER'
q0.C   = (  clk );


